# Project-relative runtime directories. Keep these relative unless you intentionally
# want to modify project_config.py to allow external storage.
SAR_DOWNLOAD_DIR=downloads
SAR_OUTPUT_DIR=outputs
SAR_LOG_DIR=logs
SAR_TEMP_DIR=tmp

# ESA SNAP must be installed and SNAP-Python integration must already be
# configured. The app first tries the active Python environment, then checks
# the current user's common .snap/snap-python directory automatically.
